# Shared
APP_ENV=local
LOG_LEVEL=INFO

# API / worker
DATABASE_URL=postgresql+psycopg://ghost:ghost@postgres:5432/market_os
REDIS_URL=redis://redis:6379/0
DEV_AUTH_EMAIL=demo@market-os.local
DEV_AUTH_PASSWORD=demo-password
TINYFISH_API_KEY=
TINYFISH_SEARCH_URL=https://api.search.tinyfish.ai
TINYFISH_FETCH_URL=https://api.fetch.tinyfish.ai
TINYFISH_AGENT_URL=https://agent.tinyfish.ai/v1/automation/run
TINYFISH_TIMEOUT_SECONDS=20
TINYFISH_MAX_RETRIES=2
RISK_ALERT_THRESHOLD=70

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional placeholders
GUILD_AI_ENDPOINT=
VAPI_API_KEY=
WUNDERGRAPH_URL=
NEXLA_API_KEY=
CHAINGUARD_POLICY_REF=
AKASH_DEPLOYMENT_ID=
